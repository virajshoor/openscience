{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenScience",
  "version": "0.1.0",
  "identifier": "ai.openscience.workbench",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": false,
    "security": { "csp": null },
    "windows": [
      {
        "title": "OpenScience",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}